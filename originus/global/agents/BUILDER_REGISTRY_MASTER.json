{
  "_schema": "sfl-builder-registry-v1",
  "_version": "1.0.0",
  "_description": "Master registry of all callable SFL builders. Each builder is registered, callable via /api/builders/:id/invoke, storable to R2, and monetizable where applicable.",
  "_api_endpoint": "/api/builders",
  "_invoke_endpoint": "/api/builders/:id/invoke",
  "builders": {
    "app_builder": {
      "id": "app_builder",
      "name": "App Builder",
      "category": "web",
      "description": "Builds and scaffolds web app pages and SPA components for the SFL network.",
      "status": "registered",
      "callable": true,
      "trigger": { "api": "/api/builders/app_builder/invoke", "dashboard": true, "telegram": false },
      "input_schema": { "project_id": "string", "template": "string", "domain": "string", "content": "object" },
      "output_path": "originus/content/output/apps/{project_id}/",
      "delivery_path": "originus/sites/{domain}/",
      "monetization": { "tier_required": "pro", "billable": false },
      "queue_mode": "sync"
    },
    "assets_builder": {
      "id": "assets_builder",
      "name": "Assets Builder",
      "category": "media",
      "description": "Processes, optimizes, and catalogs brand assets. Stores to R2 with canonical naming.",
      "status": "registered",
      "callable": true,
      "trigger": { "api": "/api/builders/assets_builder/invoke", "dashboard": true, "telegram": false },
      "input_schema": { "asset_type": "string", "source_url": "string", "brand": "string", "target_path": "string" },
      "output_path": "originus/global/assets/{brand}/",
      "delivery_path": "originus/public/assets/",
      "monetization": { "tier_required": "oem", "billable": false },
      "queue_mode": "async"
    },
    "house_signature_builder": {
      "id": "house_signature_builder",
      "name": "House Signature Builder",
      "category": "documents",
      "description": "Generates official SFL house signature documents. Owner is final signer.",
      "status": "registered",
      "callable": true,
      "trigger": { "api": "/api/builders/house_signature_builder/invoke", "dashboard": true, "telegram": false },
      "input_schema": { "deal_id": "string", "parties": "array", "terms": "object", "signature_required": true },
      "output_path": "originus/deals/generated_pdfs/house_sig_{deal_id}.pdf",
      "delivery_path": "originus/private/reports/",
      "monetization": { "tier_required": "licensing", "billable": false },
      "queue_mode": "sync",
      "governance": "owner_must_sign"
    },
    "bot_builder": {
      "id": "bot_builder",
      "name": "Bot Builder",
      "category": "automation",
      "description": "Generates and registers bot configuration, command maps, and handler stubs.",
      "status": "registered",
      "callable": true,
      "trigger": { "api": "/api/builders/bot_builder/invoke", "dashboard": true, "telegram": false },
      "input_schema": { "bot_name": "string", "commands": "array", "domain": "string" },
      "output_path": "originus/content/output/bots/{bot_name}/",
      "delivery_path": "originus/global/system/",
      "monetization": { "tier_required": "oem", "billable": false },
      "queue_mode": "sync"
    },
    "cartoon_builder": {
      "id": "cartoon_builder",
      "name": "Cartoon Builder",
      "category": "media",
      "description": "Builds cartoon/animated content specs for the RATOU universe and SFL IP layer.",
      "status": "registered",
      "callable": true,
      "trigger": { "api": "/api/builders/cartoon_builder/invoke", "dashboard": true, "telegram": false },
      "input_schema": { "universe": "string", "scene": "string", "characters": "array", "format": "string" },
      "output_path": "originus/content/output/cartoons/{scene}/",
      "delivery_path": "originus/sites/codexworldtv.homes/",
      "monetization": { "tier_required": "pro", "billable": true, "price_cents": 0 },
      "queue_mode": "async",
      "ip_association": ["RATOU", "CODEX SHARDS"]
    },
    "mini_web_games_builder": {
      "id": "mini_web_games_builder",
      "name": "Mini Web Games Builder",
      "category": "games",
      "description": "Builds interactive mini web game manifests and asset bundles for lumengame.vip.",
      "status": "registered",
      "callable": true,
      "trigger": { "api": "/api/builders/mini_web_games_builder/invoke", "dashboard": true, "telegram": false },
      "input_schema": { "game_id": "string", "title": "string", "genre": "string", "universe": "string" },
      "output_path": "originus/content/output/games/{game_id}/",
      "delivery_path": "originus/sites/lumengame.vip/",
      "monetization": { "tier_required": "pro", "billable": true },
      "queue_mode": "async",
      "ip_association": ["RATOU"]
    },
    "snippets_builder": {
      "id": "snippets_builder",
      "name": "Snippets Builder",
      "category": "content",
      "description": "Generates structured content snippets for auto-publish, feed, or Telegram delivery.",
      "status": "registered",
      "callable": true,
      "trigger": { "api": "/api/builders/snippets_builder/invoke", "dashboard": true, "telegram": "/snippet" },
      "input_schema": { "topic": "string", "tone": "string", "length": "number", "channel": "string" },
      "output_path": "originus/content/output/snippets/{ts}/",
      "delivery_path": "originus/content/feed/",
      "monetization": { "tier_required": null, "billable": false },
      "queue_mode": "sync"
    },
    "ebook_builder": {
      "id": "ebook_builder",
      "name": "Ebook Builder",
      "category": "content",
      "description": "Generates structured ebook content with chapters, cover, and metadata. PDF output.",
      "status": "registered",
      "callable": true,
      "trigger": { "api": "/api/builders/ebook_builder/invoke", "dashboard": true, "telegram": false },
      "input_schema": { "title": "string", "author": "string", "chapters": "array", "domain": "string" },
      "output_path": "originus/products/digital/ebooks/{title}/",
      "delivery_path": "originus/delivery/records/",
      "monetization": { "tier_required": "starter", "billable": true },
      "queue_mode": "async"
    },
    "audiobook_builder": {
      "id": "audiobook_builder",
      "name": "Audiobook Builder",
      "category": "audio",
      "description": "Builds audiobook structure, manifest, and chapter sequence. Connects to audio pipeline.",
      "status": "registered",
      "callable": true,
      "trigger": { "api": "/api/builders/audiobook_builder/invoke", "dashboard": true, "telegram": false },
      "input_schema": { "title": "string", "source_text": "string", "voice_profile": "string" },
      "output_path": "originus/content/output/audiobooks/{title}/",
      "delivery_path": "originus/products/digital/audio/",
      "monetization": { "tier_required": "pro", "billable": true },
      "queue_mode": "async"
    },
    "video_builder": {
      "id": "video_builder",
      "name": "Video Builder",
      "category": "media",
      "description": "Builds video production manifests, storyboards, and scene structure for SFL content.",
      "status": "registered",
      "callable": true,
      "trigger": { "api": "/api/builders/video_builder/invoke", "dashboard": true, "telegram": false },
      "input_schema": { "title": "string", "scenes": "array", "format": "string", "domain": "string" },
      "output_path": "originus/content/output/videos/{title}/",
      "delivery_path": "originus/sites/codexworldtv.homes/",
      "monetization": { "tier_required": "pro", "billable": true },
      "queue_mode": "async",
      "ip_association": ["RATOU", "CODEX SHARDS"]
    },
    "image_rebuilder": {
      "id": "image_rebuilder",
      "name": "Image Rebuilder",
      "category": "media",
      "description": "Processes, optimizes, and rebuilds images. Stores canonical versions in R2.",
      "status": "registered",
      "callable": true,
      "trigger": { "api": "/api/builders/image_rebuilder/invoke", "dashboard": true, "telegram": false },
      "input_schema": { "source_path": "string", "target_format": "string", "brand": "string", "watermark": "boolean" },
      "output_path": "originus/global/assets/images/{brand}/",
      "delivery_path": "originus/public/assets/",
      "monetization": { "tier_required": "oem", "billable": false },
      "queue_mode": "async"
    },
    "deal_pdf_builder": {
      "id": "deal_pdf_builder",
      "name": "Deal PDF Builder",
      "category": "documents",
      "description": "Generates structured deal PDFs with parties, terms, and watermark. Owner is final signer.",
      "status": "registered",
      "callable": true,
      "trigger": { "api": "/api/builders/deal_pdf_builder/invoke", "dashboard": true, "telegram": false },
      "input_schema": { "deal_id": "string", "deal_type": "string", "parties": "array", "amount_cents": "number", "terms": "object" },
      "output_path": "originus/deals/generated_pdfs/deal_{deal_id}.pdf",
      "delivery_path": "originus/private/reports/",
      "monetization": { "tier_required": "licensing", "billable": false },
      "queue_mode": "sync",
      "governance": "owner_must_sign"
    },
    "offer_pack_builder": {
      "id": "offer_pack_builder",
      "name": "Offer Pack Builder",
      "category": "commerce",
      "description": "Packages offers into structured bundles with copy, pricing, and Stripe links.",
      "status": "registered",
      "callable": true,
      "trigger": { "api": "/api/builders/offer_pack_builder/invoke", "dashboard": true, "telegram": false },
      "input_schema": { "pack_id": "string", "tier": "string", "items": "array", "copy": "string" },
      "output_path": "originus/products/bundles/{pack_id}/",
      "delivery_path": "originus/products/",
      "monetization": { "tier_required": null, "billable": true },
      "queue_mode": "sync"
    },
    "landing_page_builder": {
      "id": "landing_page_builder",
      "name": "Landing Page Builder",
      "category": "web",
      "description": "Generates structured landing page content manifests served by CF Workers.",
      "status": "registered",
      "callable": true,
      "trigger": { "api": "/api/builders/landing_page_builder/invoke", "dashboard": true, "telegram": false },
      "input_schema": { "page_id": "string", "domain": "string", "headline": "string", "cta": "object", "sections": "array" },
      "output_path": "originus/sites/{domain}/{page_id}/",
      "delivery_path": "originus/hub/manifests/",
      "monetization": { "tier_required": "pro", "billable": false },
      "queue_mode": "sync"
    },
    "agent_service_builder": {
      "id": "agent_service_builder",
      "name": "Agent Service Builder",
      "category": "automation",
      "description": "Registers and configures callable agent services with routing, storage, and monetization.",
      "status": "registered",
      "callable": true,
      "trigger": { "api": "/api/builders/agent_service_builder/invoke", "dashboard": true, "telegram": false },
      "input_schema": { "agent_id": "string", "capabilities": "array", "trigger_rules": "object", "monetization": "object" },
      "output_path": "originus/global/agents/{agent_id}/",
      "delivery_path": "originus/global/agents/",
      "monetization": { "tier_required": "oem", "billable": false },
      "queue_mode": "sync"
    }
  }
}
